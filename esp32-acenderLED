#include <Arduino.h>
#include <WiFi.h>

const char *ssid = "minhaRedeRoteada;
//rede 2,4 GHZ no maximo
const char *password = "imnhaSenha";

// Atualizado para o padrão estável do ESP32
WiFiServer server(80);

// Definimos o pino 23 onde seu LED está conectado fisicamente
const int pinoLED = 23; 

void setup() {
  Serial.begin(115200);
  
  // Agora configuramos o pino CERTO onde o LED está espetado
  pinMode(pinoLED, OUTPUT);  

  delay(10);

  Serial.println();
  Serial.println();
  Serial.print("Connecting to ");
  Serial.println(ssid);

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("");
  Serial.println("WiFi connected.");
  Serial.println("IP address: ");
  Serial.println(WiFi.localIP());

  server.begin();
}

void loop() {
  // Atualizado para o padrão estável do ESP32
  WiFiClient client = server.accept();  

  if (client) {                             
    Serial.println("New Client.");  
    String currentLine = "";        
    while (client.connected()) {    
      if (client.available()) {     
        char c = client.read();     
        Serial.write(c);            
        if (c == '\n') {            

          if (currentLine.length() == 0) {
            client.println("HTTP/1.1 200 OK");
            client.println("Content-type:text/html");
            client.println();

           // Logotipo do Centro Paula Souza
client.print("<img src='https://bkpsitecpsnew.blob.core.windows.net/uploadsitecps/sites/1/2022/09/logo-cps-2022.svg' style='max-width:300px;'><br><br>");

// Título Principal
client.print("<h1 style='font-family:Arial, sans-serif; color:#333;'>Sejam bem-vindos ao Sistema de Internet das Coisas</h1><br>");

// --- ESTILIZAÇÃO DOS BOTÕES EM CSS ---
client.print("<style>");
client.print(".botao {");
client.print("  display: inline-block;");
client.print("  padding: 15px 30px;");
client.print("  font-size: 18px;");
client.print("  font-family: Arial, sans-serif;");
client.print("  font-weight: bold;");
client.print("  text-decoration: none;");
client.print("  color: #ffffff !important;"); // Agora sim, dentro do client.print correto!
client.print("  border-radius: 8px;");
client.print("  margin: 10px;");
client.print("  box-shadow: 0px 4px 6px rgba(0,0,0,0.1);");
client.print("}");
client.print(".btn-ligar { background-color: #2ECC71; }");    // Verde
client.print(".btn-desligar { background-color: #E74C3C; }"); // Vermelho
client.print("</style>");

// --- EXIBIÇÃO DOS BOTÕES ---
client.print("<a href=\"/H\" class=\"botao btn-ligar\">LIGAR O LED</a>");
client.print("<a href=\"/L\" class=\"botao btn-desligar\">DESLIGAR O LED</a><br>");

            client.println();
            break;
          } else {  
            currentLine = "";
          }
        } else if (c != '\r') {  
          currentLine += c;      
        }

        // Verifica os comandos e aciona a GPIO 23
        if (currentLine.endsWith("GET /H")) {
          digitalWrite(pinoLED, HIGH);  // Liga o LED na GPIO23
        }
        if (currentLine.endsWith("GET /L")) {
          digitalWrite(pinoLED, LOW);   // Desliga o LED na GPIO23
        }
      }
    }
    client.stop();
    Serial.println("Client Disconnected.");
  }
}
